{
  "safety-gate": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/block-destructive-ops.sh"
          }
        ]
      }
    ]
  },
  "quality-gate": {
    "enabled": false,
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/quality-gate.sh"
          }
        ]
      }
    ]
  },
  "auto-lint": {
    "enabled": false,
    "PostToolUse": [
      {
        "matcher": "write_file",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/auto-lint.sh"
          }
        ]
      }
    ]
  }
}
